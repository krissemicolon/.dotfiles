# cd
alias ..="cd .."
alias ../..="cd ../.."
alias ../../..="cd ../../.."
alias cdp="cd ~/Projects"

# ls
alias ls="ls --color=auto"
alias la="ls -la --color=auto"
alias l.='ls -d .* --color=auto'

# sudo / doas
alias fg="sudo !!"

# text editor
alias v="vim"
alias v.="vim ."
alias vi="vim -u NONE $1"

# Portage
alias semerge="emerge --search "
alias makeconf="sudo vim /etc/portage/make.conf"
alias upall="sudo layman -S; echo Calculating dependencies...; sudo emerge --sync; sudo emerge -uDNvtq @world"
alias syncall="sudo layman -S; sudo emerge --sync"
alias cleanall="sudo emerge --depclean; sudo eclean-dist -d"

# Compiling
alias mk="./configure; make; sudo make install"

# git
alias sclone="git clone --depth 1 "

# Safety
alias rm\ -rf\ ~="false"
alias sudo\ rm\ -rf\ ~="false"
